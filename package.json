{
  "name": "millionaire-royale",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev:web": "pnpm --filter @mr/web dev",
    "dev:worker": "wrangler dev",
    "build": "pnpm --filter @mr/web build",
    "build:web": "pnpm --filter @mr/web build",
    "deploy": "pnpm build:web && wrangler deploy",
    "typecheck": "pnpm -r typecheck",
    "test": "node scripts/test.mjs",
    "test:watch": "vitest",
    "questions:validate": "node scripts/validate-questions.mjs",
    "questions:seed-sql": "node scripts/generate-question-seed-sql.mjs",
    "db:migrate:local": "wrangler d1 migrations apply millionaire-royale --local",
    "db:migrate:remote": "wrangler d1 migrations apply millionaire-royale --remote",
    "db:seed:local": "wrangler d1 execute millionaire-royale --local --file=./migrations/0002_seed_questions.sql",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.3",
    "vitest": "2.1.9",
    "wrangler": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd"]
  }
}
